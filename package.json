{
  "name": "tessyl",
  "version": "0.0.0",
  "private": true,
  "description": "A full-stack application written in Voyd.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
