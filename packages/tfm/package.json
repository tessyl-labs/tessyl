{
  "name": "@tessyl/tfm",
  "version": "0.1.0",
  "description": "Validated Tessyl Flavored Markdown parser and safe HTML renderer for TypeScript and Voyd",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./adapter": {
      "types": "./dist/host/adapter.d.ts",
      "development": "./host/adapter.ts",
      "import": "./dist/host/adapter.js",
      "default": "./dist/host/adapter.js"
    },
    "./renderer.css": "./renderer.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "generated",
    "renderer.css",
    "src/*.voyd",
    "README.md"
  ],
  "voyd": {
    "source": "./src/pkg.voyd",
    "adapter": {
      "abi": 1,
      "interfaces": [
        "tessyl:tfm/parser@1",
        "tessyl:tfm/renderer@1"
      ],
      "browser": "./adapter",
      "node": "./adapter",
      "default": "./adapter"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run check:node-types",
    "check:node-types": "tsc --noEmit --strict --target ES2022 --lib ES2022 --types node --module NodeNext --moduleResolution NodeNext dist/src/index.d.ts",
    "prebuild": "npm run build --workspace=@tessyl/design-tokens && npm run generate:styles",
    "clean": "rm -rf dist",
    "dev": "vite --config playground/vite.config.mjs",
    "predev": "npm run generate:styles",
    "generate": "node ../../.voyd-source/apps/cli/bin/voyd.js generate adapter ./src --out ./generated",
    "generate:styles": "node scripts/generate-renderer-styles.mjs",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prelint": "npm run generate:styles",
    "playground:build": "npm run playground:typecheck && vite build --config playground/vite.config.mjs",
    "preplayground:build": "npm run generate:styles",
    "playground:typecheck": "tsc --noEmit -p playground/tsconfig.json",
    "pretest": "npm run generate:styles",
    "test": "node --conditions=development --import tsx --test src/**/*.test.ts host/**/*.test.ts",
    "pretypecheck": "npm run generate:styles",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tessyl/design-tokens": "*",
    "@voyd-lang/package-adapter": "file:../../.voyd-source/packages/package-adapter",
    "@voyd-lang/std": "file:../../.voyd-source/packages/std",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.1",
    "@voyd-lang/cli": "file:../../.voyd-source/apps/cli",
    "@voyd-lang/sdk": "file:../../.voyd-source/packages/sdk",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.0"
  }
}
