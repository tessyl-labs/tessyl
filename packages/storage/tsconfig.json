{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "noEmit": true,
    "types": ["node"],
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "local/**/*.ts", "hosted/**/*.ts", "host/**/*.ts", "generated/**/*.ts", "conformance/**/*.ts", "tests/**/*.ts"]
}
