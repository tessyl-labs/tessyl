//! A small, provider-neutral agent harness for Voyd.
//!
//! The harness owns the model/tool loop while `Llm` is the host effect that
//! adapters implement. This keeps tools as ordinary Voyd functions and keeps
//! provider-specific networking outside the Wasm module.

use std::array::Array
use std::msgpack::MsgPack
use std::msgpack::self as msgpack
use std::optional::types::all
use std::string::type::String
use super::tool::{ Tool, ToolDefinition, ToolFactory, ToolMarker, invoke_tool }

pub obj User {}
pub obj Assistant {}
pub obj System {}
pub type Role = User | Assistant | System

pub obj Message { api role: Role, api content: String }
pub obj ToolCall {
  api call_id: String,
  api name: String,
  api arguments: String
}
pub obj ToolOutput { api call_id: String, api output: String }
/// Opaque provider-native context returned by a compaction operation.
pub obj ProviderItem {
  api provider: String,
  api data: String
}
pub type InputItem = Message | ToolCall | ToolOutput | ProviderItem

pub obj Text { api text: String }
pub type ModelOutput = Text | ToolCall

pub obj Usage {
  api input_tokens: i32,
  api output_tokens: i32,
  api total_tokens: i32
}

pub obj ModelRequest {
  api model: String,
  api instructions: String,
  api input: Array<InputItem>,
  api input_delta: Array<InputItem>,
  api tools: Array<ToolDefinition>,
  api continuation_token?: String,
  api retain_continuation: bool
}

pub obj ModelResponse {
  api id: String,
  api continuation_token?: String,
  api output: Array<ModelOutput>,
  api usage: Usage
}

/// Controls automatic context compaction at safe model-call boundaries.
pub obj CompactionConfig {
  api trigger_tokens: i32,
  api keep_recent_items: i32,
  api instructions: String,
  api model: String,
  api prefer_native: bool
}

pub obj CompactionRequest {
  api model: String,
  api instructions: String,
  api input: Array<InputItem>,
  api input_delta: Array<InputItem>,
  api tools: Array<ToolDefinition>,
  api continuation_token?: String,
  api retain_continuation: bool,
  api overflow_recovery: bool,
  api compaction: CompactionConfig
}

pub obj CompactionResponse {
  api input: Array<InputItem>,
  api continuation_token?: String,
  api usage: Usage
}

pub obj LlmError {
  api code: String,
  api message: String,
  api retryable: bool
}

pub obj LlmSucceeded { api response: ModelResponse }
pub obj LlmFailed { api error: LlmError }
pub type LlmResult = LlmSucceeded | LlmFailed

pub obj CompactionSucceeded { api response: CompactionResponse }
pub obj CompactionFailed { api error: LlmError }
pub type CompactionResult = CompactionSucceeded | CompactionFailed

pub obj Started { api response_id: String }
pub obj TextDelta { api delta: String }
pub type StreamEvent = Started | TextDelta

pub obj Event { api cursor: String, api event: StreamEvent }
pub obj Done { api response: ModelResponse }
pub type StreamStep = Event | Done

pub obj StreamSucceeded { api step: StreamStep }
pub obj StreamFailed { api error: LlmError }
pub type StreamResult = StreamSucceeded | StreamFailed

/// Provider adapter surface used by the agent harness.
@effect(id: "tessyl.agents.llm.v3")
pub eff Llm
  respond(tail, payload: MsgPack) -> MsgPack
  compact(tail, payload: MsgPack) -> MsgPack
  open_stream(tail, payload: MsgPack) -> MsgPack
  next_stream(tail, payload: MsgPack) -> MsgPack

pub obj Agent {
  name: String,
  instructions: String,
  model: String,
  tools: Array<Tool>,
  max_turns: i32,
  compaction: Option<CompactionConfig>
}

pub obj InvalidConfig { api message: String }
pub obj InvalidHistory { api message: String }
pub obj LlmFailure { api error: LlmError }
pub obj UnknownTool { api name: String }
pub obj ToolFailure { api name: String, api message: String }
pub obj CompactionFailure { api error: LlmError }
pub obj MaxTurns { api max_turns: i32 }
pub type AgentError = InvalidConfig | InvalidHistory | LlmFailure | CompactionFailure | UnknownTool | ToolFailure | MaxTurns

pub obj Completed {
  api output: String,
  api history: Array<InputItem>,
  api turns: i32,
  api usage: Usage
}
pub obj Failed {
  api error: AgentError,
  api history: Array<InputItem>,
  api turns: i32,
  api usage: Usage
}
pub type RunResult = Completed | Failed

enum RunMode
  Regular
  Streaming { on_event: fn(StreamEvent) -> void }

pub fn user_message(content: String) -> InputItem
  Message { role: User {}, content: content }

pub fn assistant_message(content: String) -> InputItem
  Message { role: Assistant {}, content: content }

pub fn system_message(content: String) -> InputItem
  Message { role: System {}, content: content }

/// Creates an automatic context-compaction policy. The adapter may use native
/// provider compaction when preferred, otherwise it must return a portable
/// compacted context.
pub fn compaction({
  trigger_tokens: i32,
  keep_recent_items: i32 = 4,
  instructions: String = "",
  model: String = "",
  prefer_native: bool = true
}) -> CompactionConfig
  CompactionConfig {
    trigger_tokens: trigger_tokens,
    keep_recent_items: keep_recent_items,
    instructions: instructions,
    model: model,
    prefer_native: prefer_native
  }

/// Creates an agent. `max_turns` bounds model calls, including tool turns.
pub fn agent({
  name: String,
  instructions: String,
  model: String,
  tools?: Array<ToolFactory>,
  max_turns?: i32,
  compaction?: CompactionConfig
}) -> Agent
  Agent {
    name: name,
    instructions: instructions,
    model: model,
    tools: materialize_tools(tools ?? Array<ToolFactory>::init()),
    max_turns: max_turns ?? 8,
    compaction: compaction
  }

/// Runs an agent until it produces a final text response or fails.
pub fn run(agent: Agent, { input: Array<InputItem> }): (Llm, open) -> RunResult
  run_loop(agent, input, RunMode::Regular {})

/// Runs an agent and reports model stream events as they arrive.
pub fn run_streamed(
  agent: Agent,
  { input: Array<InputItem>, on_event: fn(StreamEvent) -> void }
): (Llm, open) -> RunResult
  run_loop(agent, input, RunMode::Streaming { on_event: on_event })

fn run_loop(agent: Agent, initial_input: Array<InputItem>, mode: RunMode): (Llm, open) -> RunResult
  var ~history = copy_input(initial_input)
  let definitions = tool_definitions(agent.tools)
  var input_delta = copy_input(initial_input)
  var continuation_token: Option<String> = None {}
  var turns = 0
  var usage = empty_usage()
  var context_tokens = estimate_request_tokens(agent.instructions, history, definitions)
  var opaque_context_tokens = 0
  var context_retry = false

  if agent.max_turns <= 0:
    return failed(
      AgentError::InvalidConfig { message: "agent max_turns must be greater than zero" },
      history,
      turns,
      usage
    )

  match(agent.compaction)
    Some<CompactionConfig> { value }:
      if value.trigger_tokens <= 0:
        return failed(
          AgentError::InvalidConfig { message: "compaction trigger_tokens must be greater than zero" },
          history,
          turns,
          usage
        )
      if value.keep_recent_items < 0:
        return failed(
          AgentError::InvalidConfig { message: "compaction keep_recent_items must not be negative" },
          history,
          turns,
          usage
        )
    None:
      void

  if not valid_compacted_input(history):
    return failed(
      AgentError::InvalidHistory {
        message: "initial input contains an orphaned, reversed, or duplicate tool call/output"
      },
      history,
      turns,
      usage
    )

  while turns < agent.max_turns:
    match(agent.compaction)
      Some<CompactionConfig> { value }:
        if not context_retry and should_compact(value, history, context_tokens):
          let compacted = compact_context(CompactionRequest {
            model: agent.model,
            instructions: agent.instructions,
            input: copy_input(history),
            input_delta: input_delta,
            tools: definitions,
            continuation_token: continuation_token,
            retain_continuation: true,
            overflow_recovery: false,
            compaction: value
          })
          match(compacted)
            CompactionResult::CompactionFailed { error }:
              return failed(
                AgentError::CompactionFailure { error: error },
                history,
                turns,
                usage
              )
            CompactionResult::CompactionSucceeded { response }:
              usage = add_usage(usage, response.usage)
              if not valid_compacted_input(response.input):
                return failed(
                  AgentError::CompactionFailure { error: invalid_compaction_error() },
                  history,
                  turns,
                  usage
                )
              let baseline_estimate = estimate_request_tokens(agent.instructions, history, definitions)
              let baseline_tokens = if context_tokens > baseline_estimate then: context_tokens else: baseline_estimate
              let next_context_tokens = estimate_context_after_compaction(
                agent.instructions,
                response.input,
                definitions,
                response.usage.output_tokens
              )
              if not compaction_made_progress(
                history,
                response.input,
                baseline_tokens,
                next_context_tokens
              ):
                return failed(
                  AgentError::CompactionFailure { error: compaction_no_progress_error() },
                  history,
                  turns,
                  usage
                )
              history = copy_input(response.input)
              input_delta = compacted_input_delta(response.input, response.continuation_token)
              continuation_token = response.continuation_token
              opaque_context_tokens = if has_provider_item(history) then: response.usage.output_tokens else: 0
              context_tokens = next_context_tokens
      None:
        void

    turns = turns + 1
    let request = ModelRequest {
      model: agent.model,
      instructions: agent.instructions,
      input: copy_input(history),
      input_delta: input_delta,
      tools: definitions,
      continuation_token: continuation_token,
      retain_continuation: true
    }
    let model_result = match(mode)
      RunMode::Regular:
        request_model(request)
      RunMode::Streaming { on_event }:
        consume_stream(request, on_event)

    match(model_result)
      LlmResult::LlmFailed { error }:
        if not context_retry and is_context_limit_error(error):
          match(agent.compaction)
            Some<CompactionConfig> { value }:
              if history.len() > 0:
                let recovery_config = CompactionConfig {
                  trigger_tokens: value.trigger_tokens,
                  keep_recent_items: 0,
                  instructions: value.instructions,
                  model: value.model,
                  prefer_native: false
                }
                let compacted = compact_context(CompactionRequest {
                  model: agent.model,
                  instructions: agent.instructions,
                  input: copy_input(history),
                  input_delta: input_delta,
                  tools: definitions,
                  continuation_token: continuation_token,
                  retain_continuation: true,
                  overflow_recovery: true,
                  compaction: recovery_config
                })
                match(compacted)
                  CompactionResult::CompactionFailed { error: compaction_error }:
                    return failed(
                      AgentError::CompactionFailure { error: compaction_error },
                      history,
                      turns,
                      usage
                    )
                  CompactionResult::CompactionSucceeded { response }:
                    usage = add_usage(usage, response.usage)
                    if not valid_compacted_input(response.input):
                      return failed(
                        AgentError::CompactionFailure { error: invalid_compaction_error() },
                        history,
                        turns,
                        usage
                      )
                    let baseline_estimate = estimate_request_tokens(
                      agent.instructions,
                      history,
                      definitions
                    )
                    let observed_baseline = if context_tokens > baseline_estimate then: context_tokens else: baseline_estimate
                    let baseline_tokens = if value.trigger_tokens > observed_baseline then: value.trigger_tokens else: observed_baseline
                    let next_context_tokens = estimate_context_after_compaction(
                      agent.instructions,
                      response.input,
                      definitions,
                      response.usage.output_tokens
                    )
                    if not compaction_made_progress(
                      history,
                      response.input,
                      baseline_tokens,
                      next_context_tokens
                    ):
                      return failed(
                        AgentError::CompactionFailure { error: compaction_no_progress_error() },
                        history,
                        turns,
                        usage
                      )
                    history = copy_input(response.input)
                    input_delta = compacted_input_delta(response.input, response.continuation_token)
                    continuation_token = response.continuation_token
                    opaque_context_tokens = if has_provider_item(history) then: response.usage.output_tokens else: 0
                    context_tokens = next_context_tokens
                    context_retry = true
                    turns = turns - 1
                    continue
            None:
              void
        return failed(AgentError::LlmFailure { error: error }, history, turns, usage)
      LlmResult::LlmSucceeded { response }:
        context_retry = false
        usage = add_usage(usage, response.usage)
        continuation_token = response.continuation_token
        let ~tool_calls = Array<ToolCall>::init()
        var final_output = ""
        var output_index = 0
        while output_index < response.output.len():
          match(response.output.at(output_index))
            ModelOutput::Text { text }:
              final_output = final_output.concat(text)
              history.push(InputItem::Message { role: Role::Assistant {}, content: text })
            ModelOutput::ToolCall { call_id, name, arguments }:
              let call = ToolCall { call_id: call_id, name: name, arguments: arguments }
              tool_calls.push(call)
              history.push(call)
          output_index = output_index + 1

        if tool_calls.len() == 0:
          return RunResult::Completed {
            output: final_output,
            history: history,
            turns: turns,
            usage: usage
          }

        let ~tool_outputs = Array<InputItem>::with_capacity(tool_calls.len())
        var call_index = 0
        while call_index < tool_calls.len():
          let call = tool_calls.at(call_index)
          match(find_tool(agent.tools, call.name))
            Some<Tool> { value: selected }:
              let result = invoke_tool(selected, call.arguments)
              if result.succeeded:
                let item = ToolOutput { call_id: call.call_id, output: result.value }
                tool_outputs.push(item)
                history.push(item)
              else:
                return failed(
                  AgentError::ToolFailure { name: call.name, message: result.value },
                  history,
                  turns,
                  usage
                )
            None:
              return failed(
                AgentError::UnknownTool { name: call.name },
                history,
                turns,
                usage
              )
          call_index = call_index + 1
        input_delta = tool_outputs
        let observed_tokens = response.usage.input_tokens + response.usage.output_tokens +
          estimate_input_tokens(tool_outputs)
        let estimated_tokens = estimate_context_after_compaction(
          agent.instructions,
          history,
          definitions,
          opaque_context_tokens
        )
        if has_provider_item(history) and response.usage.input_tokens > 0:
          context_tokens = observed_tokens
        else:
          context_tokens = if observed_tokens > estimated_tokens then: observed_tokens else: estimated_tokens

  failed(AgentError::MaxTurns { max_turns: agent.max_turns }, history, turns, usage)

fn consume_stream(
  request: ModelRequest,
  on_event: fn(StreamEvent) -> void
): (Llm, open) -> LlmResult
  consume_stream_result(open_model_stream(request), on_event)

fn consume_stream_result(
  result: StreamResult,
  on_event: fn(StreamEvent) -> void
): (Llm, open) -> LlmResult
  match(result)
    StreamResult::StreamFailed { error }:
      LlmResult::LlmFailed { error: error }
    StreamResult::StreamSucceeded { step }:
      match(step)
        StreamStep::Done { response }:
          LlmResult::LlmSucceeded { response: response }
        StreamStep::Event { cursor, event }:
          on_event(event)
          consume_stream_result(next_model_stream(cursor), on_event)

fn request_model(request: ModelRequest): Llm -> LlmResult
  msgpack::unpack_boundary_value<LlmResult>(
    Llm::respond(msgpack::pack_boundary_value<ModelRequest>(request))
  )

fn compact_context(request: CompactionRequest): Llm -> CompactionResult
  msgpack::unpack_boundary_value<CompactionResult>(
    Llm::compact(msgpack::pack_boundary_value<CompactionRequest>(request))
  )

fn open_model_stream(request: ModelRequest): Llm -> StreamResult
  msgpack::unpack_boundary_value<StreamResult>(
    Llm::open_stream(msgpack::pack_boundary_value<ModelRequest>(request))
  )

fn next_model_stream(cursor: String): Llm -> StreamResult
  msgpack::unpack_boundary_value<StreamResult>(
    Llm::next_stream(msgpack::pack_boundary_value<String>(cursor))
  )

fn tool_definitions(tools: Array<Tool>) -> Array<ToolDefinition>
  let ~definitions = Array<ToolDefinition>::with_capacity(tools.len())
  var index = 0
  while index < tools.len():
    let current = tools.at(index)
    definitions.push(ToolDefinition {
      name: current.name,
      description: current.description,
      parameters_shape: current.parameters_shape,
      strict: current.strict
    })
    index = index + 1
  definitions

fn materialize_tools(factories: Array<ToolFactory>) -> Array<Tool>
  let ~tools = Array<Tool>::with_capacity(factories.len())
  var index = 0
  while index < factories.len():
    let factory = factories.at(index)
    tools.push(factory(ToolMarker {}))
    index = index + 1
  tools

fn find_tool(tools: Array<Tool>, name: String) -> Option<Tool>
  var index = 0
  while index < tools.len():
    let current = tools.at(index)
    if current.name.equals(name):
      return Some<Tool> { value: current }
    index = index + 1
  None {}

fn copy_input(input: Array<InputItem>) -> Array<InputItem>
  let ~copy = Array<InputItem>::with_capacity(input.len())
  var index = 0
  while index < input.len():
    copy.push(input.at(index))
    index = index + 1
  copy

fn should_compact(
  config: CompactionConfig,
  input: Array<InputItem>,
  context_tokens: i32
) -> bool
  input.len() > 0 and context_tokens >= config.trigger_tokens

fn compacted_input_delta(
  input: Array<InputItem>,
  continuation_token: Option<String>
) -> Array<InputItem>
  match(continuation_token)
    Some<String>:
      Array<InputItem>::init()
    None:
      copy_input(input)

fn valid_compacted_input(input: Array<InputItem>) -> bool
  var index = 0
  while index < input.len():
    match(input.at(index))
      InputItem::ToolCall { call_id }:
        if not valid_tool_pair(input, call_id):
          return false
      InputItem::ToolOutput { call_id }:
        if not valid_tool_pair(input, call_id):
          return false
      else:
        void
    index = index + 1
  true

fn compaction_made_progress(
  previous: Array<InputItem>,
  replacement: Array<InputItem>,
  previous_tokens: i32,
  replacement_tokens: i32
) -> bool
  replacement.len() > 0 and
    replacement_tokens < previous_tokens and
    not same_input(previous, replacement)

fn same_input(left: Array<InputItem>, right: Array<InputItem>) -> bool
  if left.len() != right.len():
    return false
  var index = 0
  while index < left.len():
    if not same_input_item(left.at(index), right.at(index)):
      return false
    index = index + 1
  true

fn same_input_item(left: InputItem, right: InputItem) -> bool
  match(left)
    InputItem::Message { role, content }:
      match(right)
        InputItem::Message { role: candidate_role, content: candidate_content }:
          same_role(role, candidate_role) and content.equals(candidate_content)
        else:
          false
    InputItem::ToolCall { call_id, name, arguments }:
      match(right)
        InputItem::ToolCall {
          call_id: candidate_id,
          name: candidate_name,
          arguments: candidate_arguments
        }:
          call_id.equals(candidate_id) and name.equals(candidate_name) and
            arguments.equals(candidate_arguments)
        else:
          false
    InputItem::ToolOutput { call_id, output }:
      match(right)
        InputItem::ToolOutput { call_id: candidate_id, output: candidate_output }:
          call_id.equals(candidate_id) and output.equals(candidate_output)
        else:
          false
    InputItem::ProviderItem { provider, data }:
      match(right)
        InputItem::ProviderItem { provider: candidate_provider, data: candidate_data }:
          provider.equals(candidate_provider) and data.equals(candidate_data)
        else:
          false

fn same_role(left: Role, right: Role) -> bool
  match(left)
    Role::User:
      match(right)
        Role::User:
          true
        else:
          false
    Role::Assistant:
      match(right)
        Role::Assistant:
          true
        else:
          false
    Role::System:
      match(right)
        Role::System:
          true
        else:
          false

fn valid_tool_pair(input: Array<InputItem>, call_id: String) -> bool
  var call_count = 0
  var output_count = 0
  var call_index = -1
  var output_index = -1
  var index = 0
  while index < input.len():
    match(input.at(index))
      InputItem::ToolCall { call_id: candidate }:
        if candidate.equals(call_id):
          call_count = call_count + 1
          call_index = index
      InputItem::ToolOutput { call_id: candidate }:
        if candidate.equals(call_id):
          output_count = output_count + 1
          output_index = index
      else:
        void
    index = index + 1
  call_count == 1 and output_count == 1 and call_index < output_index

fn invalid_compaction_error() -> LlmError
  LlmError {
    code: "invalid_compaction_context",
    message: "compacted context contains an unpaired tool call or output",
    retryable: false
  }

fn compaction_no_progress_error() -> LlmError
  LlmError {
    code: "compaction_no_progress",
    message: "compacted context must be non-empty, changed, and smaller than the context it replaces",
    retryable: false
  }

fn is_context_limit_error(error: LlmError) -> bool
  let known_code = error.code.equals("context_length_exceeded") or
    error.code.equals("context_window_exceeded") or
    error.code.equals("input_too_long") or
    error.code.equals("prompt_too_long")
  if known_code:
    return true
  let message = error.message.lowered()
  message.contains("context length") or
    message.contains("context window") or
    message.contains("too many tokens") or
    message.contains("prompt is too long") or
    message.contains("input is too long")

fn estimate_request_tokens(
  instructions: String,
  input: Array<InputItem>,
  tools: Array<ToolDefinition>
) -> i32
  var bytes = instructions.byte_len()
  var tool_index = 0
  while tool_index < tools.len():
    let tool = tools.at(tool_index)
    bytes = bytes + tool.name.byte_len() + tool.description.byte_len() +
      tool.parameters_shape.byte_len() + 24
    tool_index = tool_index + 1
  ((bytes + 3) / 4) + estimate_input_tokens(input)

fn estimate_context_after_compaction(
  instructions: String,
  input: Array<InputItem>,
  tools: Array<ToolDefinition>,
  compacted_output_tokens: i32
) -> i32
  if compacted_output_tokens <= 0 or not has_provider_item(input):
    return estimate_request_tokens(instructions, input, tools)

  var bytes = instructions.byte_len()
  var tool_index = 0
  while tool_index < tools.len():
    let tool = tools.at(tool_index)
    bytes = bytes + tool.name.byte_len() + tool.description.byte_len() +
      tool.parameters_shape.byte_len() + 24
    tool_index = tool_index + 1
  var tokens = ((bytes + 3) / 4) + compacted_output_tokens
  var input_index = 0
  while input_index < input.len():
    let item_tokens = match(input.at(input_index))
      InputItem::Message { content }:
        ((content.byte_len() + 3) / 4) + 8
      InputItem::ToolCall { call_id, name, arguments }:
        ((call_id.byte_len() + name.byte_len() + arguments.byte_len() + 3) / 4) + 8
      InputItem::ToolOutput { call_id, output }:
        ((call_id.byte_len() + output.byte_len() + 3) / 4) + 8
      InputItem::ProviderItem { data }:
        8
    tokens = tokens + item_tokens
    input_index = input_index + 1
  tokens

fn has_provider_item(input: Array<InputItem>) -> bool
  var index = 0
  while index < input.len():
    match(input.at(index))
      InputItem::ProviderItem { data }:
        return true
      else:
        void
    index = index + 1
  false

fn estimate_input_tokens(input: Array<InputItem>) -> i32
  var tokens = 0
  var index = 0
  while index < input.len():
    let bytes = match(input.at(index))
      InputItem::Message { content }:
        content.byte_len()
      InputItem::ToolCall { call_id, name, arguments }:
        call_id.byte_len() + name.byte_len() + arguments.byte_len()
      InputItem::ToolOutput { call_id, output }:
        call_id.byte_len() + output.byte_len()
      InputItem::ProviderItem { provider, data }:
        provider.byte_len() + data.byte_len()
    tokens = tokens + ((bytes + 3) / 4) + 8
    index = index + 1
  tokens

fn empty_usage() -> Usage
  Usage { input_tokens: 0, output_tokens: 0, total_tokens: 0 }

fn add_usage(left: Usage, right: Usage) -> Usage
  Usage {
    input_tokens: left.input_tokens + right.input_tokens,
    output_tokens: left.output_tokens + right.output_tokens,
    total_tokens: left.total_tokens + right.total_tokens
  }

fn failed(
  error: AgentError,
  history: Array<InputItem>,
  turns: i32,
  usage: Usage
) -> RunResult
  RunResult::Failed { error: error, history: history, turns: turns, usage: usage }
